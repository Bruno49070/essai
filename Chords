<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<title>Guitar Progression Builder V14</title>

<style>
body { margin:0; font-family:Arial,sans-serif; background:#101114; color:white; }
.app { max-width:1150px; margin:auto; padding:25px; }
.version { text-align:center; color:#f2b84b; font-weight:bold; margin-bottom:12px; }

.controls,.progression-zone,.micro-zone {
  background:#181a20;
  padding:18px;
  border-radius:22px;
  margin-bottom:20px;
}

.controls,.actions {
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:12px;
}

select,input,button {
  padding:11px;
  border:none;
  border-radius:12px;
  font-size:15px;
}

select,input { background:#252936; color:white; }

button {
  background:linear-gradient(135deg,#2f80ed,#9b51e0);
  color:white;
  cursor:pointer;
}

button.secondary { background:#252936; }

.progression { display:flex; flex-wrap:wrap; gap:10px; align-items:center; }

.pill {
  padding:12px 16px;
  border-radius:999px;
  font-weight:bold;
}

.pill.tonic { background:#2f80ed; }
.pill.sub { background:#27ae60; }
.pill.dom { background:#eb5757; }

.arrow { color:#aaa; }

.legend {
  display:flex;
  flex-wrap:wrap;
  gap:14px;
  margin-top:14px;
  color:#aaa;
  font-size:14px;
}

.legend span { display:flex; align-items:center; gap:6px; }

.dot {
  width:12px;
  height:12px;
  border-radius:50%;
  display:inline-block;
}

.cards {
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(230px,1fr));
  gap:18px;
}

.card {
  background:#181a20;
  border-radius:24px;
  padding:18px;
  cursor:pointer;
  min-height:330px;
}

.card:hover { transform:translateY(-4px); }

.tonic { border-top:8px solid #2f80ed; }
.sub { border-top:8px solid #27ae60; }
.dom { border-top:8px solid #eb5757; }

.chord { font-size:32px; margin-bottom:8px; }
.effect { color:#aaa; margin-bottom:10px; min-height:38px; }

.diagram {
  background:rgba(255,255,255,0.06);
  border-radius:18px;
  padding:10px;
}

.diagram svg { width:100%; height:185px; }

.note {
  color:#aaa;
  font-size:13px;
  margin-top:8px;
}

.micro-status {
  color:#aaa;
  margin-top:10px;
  line-height:1.5;
}

.detected {
  font-size:24px;
  font-weight:bold;
  color:#f2b84b;
}

@media(max-width:800px){
  .controls,.actions { grid-template-columns:1fr; }
}
</style>
</head>

<body>
<div class="app">

<div class="version">Version V14</div>

<div class="controls">
  <select id="key"></select>

  <select id="style">
    <option value="pop">Pop</option>
    <option value="rock">Rock</option>
    <option value="folk">Folk</option>
    <option value="blues">Blues</option>
    <option value="jazz">Jazz</option>
    <option value="soul">Soul</option>
    <option value="ambient">Ambient</option>
    <option value="reggae">Reggae</option>
  </select>

  <select id="level">
    <option value="beginner">Débutant</option>
    <option value="intermediate">Intermédiaire</option>
    <option value="expert">Expert</option>
  </select>

  <input id="startChord" value="C">
</div>

<div class="actions">
  <button id="startBtn">Démarrer</button>
  <button id="undoBtn">Retour</button>
  <button id="resetBtn">Reset</button>
  <button id="typicalBtn">Progression type</button>
</div>

<div class="micro-zone">
  <div class="actions">
    <button id="micBtn">Activer le micro</button>
    <button id="stopMicBtn" class="secondary">Couper le micro</button>
    <button id="useDetectedBtn" class="secondary">Utiliser l’accord détecté</button>
  </div>
  <div class="micro-status">
    Statut : <span id="micStatus">micro inactif</span><br>
    Accord détecté : <span id="detectedChord" class="detected">-</span><br>
    Note dominante : <span id="detectedNote">-</span><br>
    Confiance : <span id="confidence">-</span>
  </div>
</div>

<div class="progression-zone">
  <div id="progression" class="progression"></div>

  <div class="legend">
    <span><i class="dot" style="background:#2f80ed"></i>Repos / résolution</span>
    <span><i class="dot" style="background:#27ae60"></i>Ouverture / mouvement</span>
    <span><i class="dot" style="background:#eb5757"></i>Tension / relance</span>
  </div>
</div>

<div id="cards" class="cards"></div>

</div>

