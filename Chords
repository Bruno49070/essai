function cleanChord(chord){
return chord
.replace("maj9","")
.replace("maj7","")
.replace("add9","")
.replace("sus4","")
.replace("9","")
.replace("7","");
}

function getRole(degree){
if(["I","i","iii","III","vi"].includes(degree)) return "tonic";
if(["ii","iv","IV","VI"].includes(degree)) return "sub";
return "dom";
}

function getTypicalDegrees(style,isMinor){
if(!isMinor){
if(style==="pop") return ["I","V","vi","IV"];
if(style==="rock") return ["I","IV","V","I"];
if(style==="folk") return ["I","IV","V","vi","IV","I"];
if(style==="blues") return ["I","IV","I","V","IV","I"];
if(style==="jazz") return ["ii","V","I","vi","ii","V","I"];
if(style==="soul") return ["I","vi","IV","ii","V","I"];
if(style==="ambient") return ["I","vi","IV","iii","IV","I"];
if(style==="reggae") return ["I","V","vi","IV"];
return ["I","V","vi","IV"];
}

if(style==="pop") return ["i","VI","VII","iv"];
if(style==="rock") return ["i","VII","VI","VII"];
if(style==="folk") return ["i","VI","VII","iv","i"];
if(style==="blues") return ["i","iv","i","VII","iv","i"];
if(style==="jazz") return ["iv","VII","III","VI","iv","v","i"];
if(style==="soul") return ["i","VI","iv","VII","i"];
if(style==="ambient") return ["i","VI","III","VII","VI","i"];
if(style==="reggae") return ["i","VII","VI","VII"];
return ["i","VI","VII","iv"];
}

function applyTypicalProgression(){
const key=document.getElementById("key").value;
const style=document.getElementById("style").value;
const level=document.getElementById("level").value;
const data=DATA[key];
const isMinor=data.degrees.includes("i");
const degrees=getTypicalDegrees(style,isMinor);

progression=[];

degrees.forEach(function(degree){
const index=data.degrees.indexOf(degree);
if(index<0) return;
const baseChord=data.chords[index];
const chord=enrichChord(baseChord,degree,style,level);
progression.push(chord);
});

render();
}

function enrichChord(chord,degree,style,level){
if(level==="beginner") return chord;

if(style==="blues"){
if(["I","IV","V","VII"].includes(degree)){
return level==="expert" ? chord+"9" : chord+"7";
}
return chord;
}

if(style==="jazz"){
if(level==="intermediate"){
if(["I","IV","III","VI"].includes(degree)) return chord+"maj7";
if(["ii","iii","vi","iv","v"].includes(degree)) return chord+"7";
if(["V","VII"].includes(degree)) return chord+"7";
return chord+"7";
}
if(level==="expert"){
if(["I","IV","III","VI"].includes(degree)) return chord+"maj7";
if(["V","VII"].includes(degree)) return chord+"9";
return chord+"7";
}
}

if(style==="soul"){
if(["I","IV","III","VI"].includes(degree)) return chord+"maj7";
if(["V","VII"].includes(degree)) return chord+"7";
return chord+"7";
}

if(style==="ambient"){
if(["I","IV","VI","III"].includes(degree)) return chord+"add9";
return level==="expert" ? chord+"sus4" : chord;
}

if(style==="reggae"){
if(level==="expert" && ["V","VII"].includes(degree)) return chord+"7";
return chord;
}

if(level==="intermediate"){
if(["I","IV"].includes(degree)) return chord+"add9";
return chord;
}

if(level==="expert"){
if(["I","IV"].includes(degree)) return chord+"maj7";
if(["V","VII"].includes(degree)) return chord+"7";
return chord+"7";
}

return chord;
}

function getEffect(role,style){
if(style==="ambient"){
if(role==="tonic") return "Planant / stable";
if(role==="sub") return "Ouverture large";
return "Tension douce";
}
if(style==="blues"){
if(role==="dom") return "Relance blues";
return "Couleur blues";
}
if(style==="jazz"){
if(role==="dom") return "Cadence / tension jazz";
if(role==="sub") return "Préparation harmonique";
return "Résolution ou couleur";
}
if(style==="reggae"){
if(role==="tonic") return "Assise rythmique";
if(role==="sub") return "Ouverture souple";
return "Relance syncopée";
}
if(role==="tonic") return "Repos / résolution";
if(role==="sub") return "Ouverture / mouvement";
return "Tension / relance";
}

function renderProgression(){
const zone=document.getElementById("progression");
zone.innerHTML="";

const key=document.getElementById("key").value;
const data=DATA[key];

progression.forEach(function(chord,index){
if(index>0){
const arrow=document.createElement("span");
arrow.className="arrow";
arrow.textContent="→";
zone.appendChild(arrow);
}

const baseChord=cleanChord(chord);
let chordIndex=data.chords.indexOf(baseChord);
if(chordIndex<0) chordIndex=0;

const degree=data.degrees[chordIndex];
const role=getRole(degree);

const pill=document.createElement("span");
pill.className="pill "+role;
pill.textContent=chord;
zone.appendChild(pill);
});
}

function renderCards(){
const key=document.getElementById("key").value;
const style=document.getElementById("style").value;
const level=document.getElementById("level").value;
const data=DATA[key];

const last=progression[progression.length-1];
const baseLast=cleanChord(last);
let index=data.chords.indexOf(baseLast);
if(index<0) index=0;

const degree=data.degrees[index];
const nextDegrees=STYLE[style][degree] || STYLE[style].I || ["IV","V","vi"];

const cards=document.getElementById("cards");
cards.innerHTML="";

nextDegrees.forEach(function(deg){
const targetIndex=data.degrees.indexOf(deg);
if(targetIndex<0) return;

const baseChord=data.chords[targetIndex];
const chord=enrichChord(baseChord,deg,style,level);
const role=getRole(deg);

const card=document.createElement("div");
card.className="card "+role;

card.innerHTML=
'<div class="chord">'+chord+'</div>'+
'<div class="effect">'+getEffect(role,style)+'</div>'+
'<div class="diagram">'+drawDiagram(chord,baseChord)+'</div>';

card.onclick=function(){
progression.push(chord);
render();
};

cards.appendChild(card);
});
}

function drawDiagram(chord,baseChord){
let used = chord;
let diagram=DIAGRAMS[chord];

if(!diagram){
used = baseChord;
diagram = DIAGRAMS[baseChord] || DIAGRAMS[cleanChord(chord)];
}

if(!diagram){
return '<div class="note">Diagramme à ajouter</div>';
}

const shape=diagram.frets;
const baseFret=diagram.baseFret || 1;

let svg='<svg viewBox="0 0 170 190">';
const startX=30;
const startY=42;
const stringGap=22;
const fretGap=24;

if(baseFret>1){
svg+='<text x="8" y="55" fill="#aaa" font-size="13">'+baseFret+'</text>';
}

for(let i=0;i<6;i++){
const x=startX+i*stringGap;
svg+='<line x1="'+x+'" y1="'+startY+'" x2="'+x+'" y2="'+(startY+fretGap*5)+'" stroke="white" stroke-width="1.5"/>';
}

for(let i=0;i<=5;i++){
const y=startY+i*fretGap;
const thick=i===0 && baseFret===1 ? 5 : 1.5;
svg+='<line x1="'+startX+'" y1="'+y+'" x2="'+(startX+stringGap*5)+'" y2="'+y+'" stroke="white" stroke-width="'+thick+'"/>';
}

shape.forEach(function(fret,i){
const x=startX+i*stringGap;

if(fret==="x"){
svg+='<text x="'+(x-5)+'" y="32" fill="#ff8a8a" font-size="15">x</text>';
}
else if(fret===0){
svg+='<text x="'+(x-5)+'" y="32" fill="#ddd" font-size="15">o</text>';
}
else{
const relativeFret=fret-baseFret+1;
const y=startY+(relativeFret-0.5)*fretGap;
svg+='<circle cx="'+x+'" cy="'+y+'" r="8" fill="#f2b84b"/>';
}
});

svg+="</svg>";

if(used !== chord){
svg += '<div class="note">Grille de base : '+used+'</div>';
}

return svg;
}

async function startMicrophone(){
try{
micStream = await navigator.mediaDevices.getUserMedia({ audio:true });
audioContext = new (window.AudioContext || window.webkitAudioContext)();
const source = audioContext.createMediaStreamSource(micStream);

analyser = audioContext.createAnalyser();
analyser.fftSize = 4096;
source.connect(analyser);

document.getElementById("micStatus").textContent = "micro actif";
micInterval = setInterval(analyzeMicrophone, 300);
}
catch(error){
document.getElementById("micStatus").textContent = "accès micro refusé ou indisponible";
}
}

function stopMicrophone(){
if(micInterval){
clearInterval(micInterval);
micInterval = null;
}

if(micStream){
micStream.getTracks().forEach(track => track.stop());
micStream = null;
}

if(audioContext){
audioContext.close();
audioContext = null;
}

document.getElementById("micStatus").textContent = "micro inactif";
}

function analyzeMicrophone(){
if(!analyser || !audioContext) return;

const bufferLength = analyser.frequencyBinCount;
const dataArray = new Uint8Array(bufferLength);
analyser.getByteFrequencyData(dataArray);

const sampleRate = audioContext.sampleRate;
const binSize = sampleRate / analyser.fftSize;

let peaks = [];

for(let i=0; i<bufferLength; i++){
const frequency = i * binSize;
const amplitude = dataArray[i];

if(frequency < 70 || frequency > 1200) continue;
if(amplitude < 80) continue;

peaks.push({ frequency, amplitude });
}

peaks.sort((a,b) => b.amplitude - a.amplitude);
peaks = peaks.slice(0, 12);

const chroma = {};
NOTE_NAMES.forEach(n => chroma[n] = 0);

peaks.forEach(function(p){
const note = frequencyToNoteName(p.frequency);
chroma[note] += p.amplitude;
});

let dominantNote = "-";
let dominantValue = 0;

Object.keys(chroma).forEach(function(note){
if(chroma[note] > dominantValue){
dominantValue = chroma[note];
dominantNote = note;
}
});

const result = detectChordFromChroma(chroma);

if(result){
lastDetectedChord = result.name;
document.getElementById("detectedChord").textContent = result.name;
document.getElementById("confidence").textContent = result.score + "%";
}
else{
lastDetectedChord = null;
document.getElementById("detectedChord").textContent = "-";
document.getElementById("confidence").textContent = "-";
}

document.getElementById("detectedNote").textContent = dominantNote;
}

function frequencyToNoteName(frequency){
const midi = Math.round(12 * Math.log2(frequency / 440) + 69);
const noteIndex = ((midi % 12) + 12) % 12;
return NOTE_NAMES[noteIndex];
}

function detectChordFromChroma(chroma){
let best = null;

CHORD_TEMPLATES.forEach(function(template){
let score = 0;
let total = 0;

Object.keys(chroma).forEach(function(note){
total += chroma[note];
});

template.notes.forEach(function(note){
score += chroma[note] || 0;
});

if(total === 0) return;

let percent = Math.round((score / total) * 100);

if(!best || percent > best.score){
best = { name: template.name, score: percent };
}
});

if(best && best.score >= 45){
return best;
}

return null;
}

function useDetectedChord(){
if(!lastDetectedChord) return;

document.getElementById("startChord").value = lastDetectedChord;
progression = [lastDetectedChord];
render();
}

window.addEventListener("DOMContentLoaded",init);
</script>

